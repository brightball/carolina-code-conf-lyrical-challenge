# Never Gonna Give You Up - brightball
# Firecracker microVM config
# firecracker --no-api --config-file never-gonna-give-you-up-brightball.json

# [Verse 1]
# We're no strangers to love
# You know the rules and so do I
{
  "boot-source": {
    "kernel_image_path": "love/us/vmlinux",
    "boot_args": "console=ttyS0 strangers_to_love=false you_know_rules=true i_know_rules=true"
  }
}

# A full commitment's what I'm thinkin' of
{
  "boot-source": {
    "boot_args": "thinking_of=full_commitment"
  }
}

# You wouldn't get this from any other guy
{
  "drives": [
    {
      "drive_id": "other-guys-excluded",
      "path_on_host": "/other_guys/exclude/i",
      "is_root_device": false,
      "is_read_only": true
    }
  ]
}

# [Pre-Chorus]
# I just wanna tell you how I'm feeling
{
  "logger": {
    "log_path": "/var/log/tell-you-feeling.log",
    "level": "Info",
    "show_level": true,
    "show_log_origin": false
  }
}

# Gotta make you understand
{
  "mmds-config": {
    "version": "V2",
    "network_interfaces": ["eth0"],
    "ipv4_address": "169.254.169.254",
    "imds_compat": false
  },
  "metadata": {
    "understood": "yes"
  }
}

# [Chorus]
# Never gonna give you up
{
  "drives": [
    {
      "drive_id": "give-you-up",
